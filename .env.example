# Hydra Framework — Variables de entorno para dev local
# Copiar a .env y ajustar valores
# cp .env.example .env

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=hydra_dev
POSTGRES_USER=hydra
POSTGRES_PASSWORD=hydra_secret
POSTGRES_PORT=5432

# URL completa (usada por runner.sh y apps)
DATABASE_URL=postgres://hydra:hydra_secret@localhost:5432/hydra_dev

# ── pgAdmin (opcional, activar con: docker compose --profile tools up) ──────
PGADMIN_EMAIL=admin@hydra.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── App secrets (rellenar con valores reales en producción) ─────────────────
JWT_SECRET=change_me_in_production_min_32_chars
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_SECRET_KEY=sk_test_change_me

# ── Integraciones (ver core/infra/.env.example para Slack/Linear) ───────────
# SLACK_TOKEN=xoxb-...
# LINEAR_API_KEY=lin_api_...
