{
  "hydra": {
    "version": "1.0.0",
    "mode": "Zen-Efficiency",
    "agent": "Claude Architect"
  },
  "layers": {
    "core": {
      "description": "Reglas inmutables, automatización y configuración del framework",
      "paths": {
        "automation": "core/automation/",
        "migrations": "core/migrations/",
        "infra": "core/infra/",
        "map": "core/MAP.json"
      }
    },
    "blueprints": {
      "description": "Módulos SQL/Backend reutilizables por cualquier startup",
      "modules": {
        "base": {
          "path": "blueprints/base/",
          "files": ["000_init.sql", "004_schema_versions.sql"],
          "status": "stable"
        },
        "auth": {
          "path": "blueprints/auth/",
          "files": ["auth.service.sql", "auth.flow.sql", "auth.context.sql", "oauth.service.sql"],
          "status": "stable",
          "migrations": ["0005_auth.sql", "0006_oauth.sql", "0014_auth_context.sql"]
        },
        "users": {
          "path": "blueprints/users/",
          "files": ["001_users.sql", "002_organizations.sql", "member_management.sql"],
          "status": "stable",
          "migrations": ["0002_users.sql", "0003_organizations.sql", "0017_member_management.sql"]
        },
        "billing": {
          "path": "blueprints/billing/",
          "files": ["003_subscriptions.sql", "billing.service.sql", "stripe.webhooks.sql"],
          "status": "stable",
          "migrations": ["0004_subscriptions.sql", "0007_billing.sql", "0016_stripe_webhooks.sql"]
        },
        "health-base": {
          "path": "blueprints/health-base/",
          "files": ["health.sql"],
          "status": "stable",
          "migrations": ["0009_health.sql"]
        },
        "seed": {
          "path": "blueprints/seed/",
          "files": ["seed.sql"],
          "status": "stable",
          "migrations": ["0010_seed.sql"]
        },
        "rate-limit": {
          "path": "blueprints/rate-limit/",
          "files": ["rate_limit.sql", "rate_limit_cleanup.sql"],
          "status": "stable",
          "migrations": ["0011_rate_limit.sql", "0013_cleanup.sql"]
        },
        "audit": {
          "path": "blueprints/audit/",
          "files": ["audit.sql"],
          "status": "stable",
          "migrations": ["0012_audit.sql"]
        },
        "onboarding": {
          "path": "blueprints/onboarding/",
          "files": ["onboarding.sql"],
          "status": "stable",
          "migrations": ["0015_onboarding.sql"]
        },
        "api-keys": {
          "path": "blueprints/api-keys/",
          "files": ["api_keys.sql"],
          "status": "stable",
          "migrations": ["0020_api_keys.sql"]
        },
        "notifications": {
          "path": "blueprints/notifications/",
          "files": ["notifications.sql"],
          "status": "stable",
          "migrations": ["0019_notifications.sql"]
        },
        "dashboard": {
          "path": "blueprints/dashboard/",
          "files": ["dashboard.sql"],
          "status": "stable",
          "migrations": ["0021_dashboard.sql"]
        },
        "billing-portal": {
          "path": "blueprints/billing/",
          "files": ["billing.portal.sql"],
          "status": "stable",
          "migrations": ["0022_billing_portal.sql"]
        },
        "slack": {
          "path": "blueprints/notifications/",
          "files": ["slack.sql"],
          "status": "stable",
          "migrations": ["0023_slack.sql"]
        },
        "utils": {
          "path": "blueprints/utils/",
          "files": ["helpers.sql"],
          "status": "stable",
          "migrations": ["0008_helpers.sql"]
        }
      }
    },
    "active_project": {
      "description": "Startup actual inyectada. Carpeta volátil — reset con inject.sh",
      "path": "active_project/",
      "config": "active_project/blueprints.json"
    }
  },
  "integrations": {
    "linear": {
      "team": "SUP",
      "workspace": "linear.app/start-up-pack",
      "mcp": ".mcp.json"
    },
    "slack": {
      "channel": "#startup-pack",
      "channel_id": "C0B3KR17K6W"
    },
    "github": {
      "repo": "https://github.com/RubenGZ/Start-up-Pack",
      "ci": ".github/workflows/ci.yml"
    }
  },
  "rules": {
    "max_lines_per_file": 250,
    "priority_order": ["Urgent", "High", "Medium", "Low"],
    "zen_sequence": ["log docs/index.html", "update CLAUDE.md", "git push", "compact"]
  }
}
